# ================================================================
# Sportsphere Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
# ================================================================

# Supabase (required — get from https://supabase.com → Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# The following are Edge Function secrets.
# Set them in Supabase Dashboard → Edge Functions → Secrets (NOT in .env for production).
# Include here only for local development with `supabase start`.

# Anthropic (for AI moderation, summaries, recommendations)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (for transactional emails — https://resend.com, free tier: 3k emails/month)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Stripe (for payments — https://stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# YouTube Data API v3 (for ImportVideos page — https://console.cloud.google.com)
YOUTUBE_API_KEY=AIza...

# Mux (for video processing — https://mux.com)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
